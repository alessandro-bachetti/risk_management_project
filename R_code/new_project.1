#####################################################
# 1. SETUP E LIBRERIE
#####################################################
rm(list = ls())
library(rstudioapi)
library(nnet)
library(car) 
library(caret) 
library(dplyr) 
library(readr)
library(MASS)
library(ggplot2)
library(patchwork)
library(corrplot)
library(vcd)       # Per V-Cramer
library(factoextra) # Per PCA visualization
library(pROC)       # Per ROC/AUC

current_path <- getActiveDocumentContext()$path
setwd(dirname(current_path))

# Caricamento dati
df <- read.csv("project_risk_raw_dataset.csv", row.names = 1)

# Funzione per la moda
getmode <- function(v) {
  uniqv <- unique(na.omit(v))
  uniqv[which.max(tabulate(match(v, uniqv)))]
}

#####################################################
# 2. DATA CLEANING & IMPUTATION + OVERALL EDA
#####################################################

target_col <- "Risk_Level"
for (col in names(df)) {
  if (col != target_col) {
    if (is.numeric(df[[col]])) {
      df[[col]][is.na(df[[col]])] <- median(df[[col]], na.rm = TRUE)
      # 🔹 NOTA: Scaling rimosso da qui per evitare data leakage
    } else {
      df[[col]] <- as.factor(df[[col]])
      df[[col]][is.na(df[[col]])] <- getmode(df[[col]])
    }
  }
}

# Variabile target ordinata correttamente
df[[target_col]] <- factor(df[[target_col]], 
                           levels = c("Low", "Medium", "High", "Critical"), 
                           ordered = TRUE)

# --- EDA PLOTS ---
num_vars <- names(df)[sapply(df, is.numeric)]

numeric_plots <- lapply(num_vars, function(var) {
  ggplot(df, aes(x = .data[[var]])) +
    geom_histogram(bins = 30, fill = "skyblue", color = "black") +
    theme_minimal() + labs(title = var)
})
final_numeric_plot <- wrap_plots(numeric_plots, ncol = 5)
#ggsave("numeric_plots.png", final_numeric_plot, width = 20, height = 15, units = "in", dpi = 300) 


cat_vars <- names(df)[sapply(df, is.factor)]
cat_vars <- cat_vars[cat_vars != target_col]
categorical_plots <- lapply(cat_vars, function(var) {
  ggplot(df, aes(x = .data[[var]])) +
    geom_bar(fill = "coral") +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1)) +
    labs(title = var)
})
final_cat_plot <- wrap_plots(categorical_plots, ncol = 5)
#ggsave("categorical_plots.png", final_cat_plot, width = 20, height = 15, units = "in", dpi = 300)


#####################################################
# 3. FEATURE SELECTION (NUMERICHE)
#####################################################

cor_mat <- cor(df[num_vars])
corrplot(cor_mat, type = "upper", method = "ellipse", tl.cex = 0.7)
high_corr <- findCorrelation(cor_mat, cutoff = 0.7, names = TRUE)
num_vars_filtered <- setdiff(num_vars, high_corr)

# ANOVA (Top 5)
p_vals_anova <- sapply(num_vars_filtered, function(x) {
  summary(aov(df[[x]] ~ df[[target_col]]))[[1]][["Pr(>F)"]][1]
})
top_anova <- names(sort(p_vals_anova)[1:5])

# PCA (Visualizzazione e Contributi)
pca_res <- princomp(df[num_vars_filtered], cor = TRUE)

fviz_pca_var(pca_res, col.var = "contrib", gradient.cols = c("#00AFBB", "#E7B800", "#FC4E07"), repel = TRUE)

fviz_contrib(pca_res, choice = "var", axes = 1, top = 10) 
fviz_contrib(pca_res, choice = "var", axes = 2, top = 10)
fviz_contrib(pca_res, choice = "var", axes = 3, top = 10)

contributions <- rowSums(pca_res$loadings[, 1:2]^2)
top_pca <- names(sort(contributions, decreasing = TRUE)[1:5])

final_num_vars <- unique(c(top_anova, top_pca))
print(final_num_vars)

#####################################################
# 4. FEATURE SELECTION (CATEGORICHE)
#####################################################

### Correlation Matrix Categorical Variables
# Create empty matrix
n <- length(cat_vars)
cramer_matrix <- matrix(NA, nrow = n, ncol = n,
                        dimnames = list(cat_vars, cat_vars))

# Loop through all pairs
for(i in 1:n){
  for(j in 1:n){
    if (i != j) {
      tab <- table(df[[cat_vars[i]]], df[[cat_vars[j]]])
      cramer_matrix[i, j] <- assocstats(tab)$cramer
    } else {
      cramer_matrix[i, j] <- 1   # variable with itself
    }
  }
}

corrplot(cramer_matrix,
         tl.srt = 45,
         type = "upper",
         method = "ellipse",
         col = colorRampPalette(c("white", "blue"))(200),
         tl.cex = 0.8,
         addCoef.col = "black",
         number.cex = 0.5,
         diag = FALSE,
         is.corr = FALSE,
         # Margini: c(basso, sinistra, alto, destra)
         mar = c(0, 0, 3, 0))

mtext("Cramér's V", side = 3, line = -10, cex = 1.2, adj = 0.55)


to_keep_cat <- cat_vars
if(length(cat_vars) > 1) {
  for(i in 1:(length(cat_vars)-1)) {
    for(j in (i+1):length(cat_vars)) {
      v_val <- assocstats(table(df[[cat_vars[i]]], df[[cat_vars[j]]]))$cramer
      if(!is.na(v_val) && v_val > 0.3) to_keep_cat <- setdiff(to_keep_cat, cat_vars[j])
    }
  }
}

p_vals_chi <- sapply(to_keep_cat, function(x) {
  chisq.test(table(df[[x]], df[[target_col]]))$p.value
})
top_categorical <- names(sort(p_vals_chi)[1:min(5, length(p_vals_chi))])

# Dataset finale
final_vars <- c(target_col, final_num_vars, top_categorical)
df_model <- df[, final_vars]

#####################################################
# 5. SPLIT E SCALING (CORREZIONE DATA LEAKAGE)
#####################################################
set.seed(123)
trainIndex <- createDataPartition(df_model[[target_col]], p = .7, list = FALSE)
data_train <- df_model[trainIndex,]
data_test  <- df_model[-trainIndex,]

# Scaling basato SOLO su training set
numeric_in_model <- intersect(names(data_train), final_num_vars)
scaling_params <- preProcess(data_train[, numeric_in_model], method = c("center", "scale"))

data_train[, numeric_in_model] <- predict(scaling_params, data_train[, numeric_in_model])
data_test[, numeric_in_model]  <- predict(scaling_params, data_test[, numeric_in_model])

#####################################################
# 6. MODELLO ORDERED LOGIT (POLR)
#####################################################

ordinal_model <- polr(Risk_Level ~ ., data = data_train, Hess = TRUE)

# Sommario con p-value
summary_m <- summary(ordinal_model)
ctable <- coef(summary_m)
p_vals <- pnorm(abs(ctable[, "t value"]), lower.tail = FALSE) * 2
ctable_with_p <- cbind(ctable, "p value" = round(p_vals, 4))
print("--- Coefficienti, t-value e p-value ---")
print(ctable_with_p)

#####################################################
# 7. ODDS RATIOS & CONFIDENCE INTERVALS
#####################################################

# 🔹 AGGIUNTA: Calcolo Odds Ratio 
or_table <- exp(cbind(OR = coef(ordinal_model), confint.default(ordinal_model)))
print("--- Odds Ratios and 95% CI ---")
print(round(or_table, 4))

#####################################################
# 8. VALUTAZIONE E ASSUNZIONI
#####################################################

# Accuracy e Matrice Confusione
preds <- predict(ordinal_model, newdata = data_test)
print(confusionMatrix(preds, data_test$Risk_Level))

# AUC Multiclass
probs <- predict(ordinal_model, newdata = data_test, type = "probs")
auc_vals <- sapply(1:ncol(probs), function(i) {
  roc(as.numeric(data_test$Risk_Level == colnames(probs)[i]), probs[, i])$auc
})
print("--- AUC per Level ---")
print(round(auc_vals, 3))

# Test Parallel Slopes (Multinomial vs Ordinal)
multi_check <- multinom(Risk_Level ~ ., data = data_train, trace = FALSE)
p_val_slopes <- pchisq(2 * (logLik(multi_check) - logLik(ordinal_model)), 
                       df = attr(logLik(multi_check), "df") - attr(logLik(ordinal_model), "df"), 
                       lower.tail = FALSE)

cat("\nTest Parallel Slopes p-value:", round(p_val_slopes, 4), "\n")
